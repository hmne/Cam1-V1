#!/usr/bin/env bash
#===============================================================================
# Shell Options (Bash Strict Mode)
#===============================================================================
# -e: Exit immediately if any command exits with non-zero status
# -u: Treat unset variables as errors
# -o pipefail: Return value of pipeline is the value of the last (rightmost)
#              command to exit with a non-zero status, or zero if all succeed
# IFS: Internal Field Separator set to newline and tab only (not space)
#      This prevents word splitting issues
#===============================================================================
#set -euo pipefail
IFS=$'\n\t'

#===============================================================================
# CONSTANTS
#===============================================================================
readonly SCRIPT_NAME="Camera Boot Script"
readonly SCRIPT_VERSION="2.0.0"
readonly SCRIPT_AUTHOR="NetStorm"

#===============================================================================
# DEVICE CONFIGURATION - CHANGE THIS FOR EACH CAMERA
#===============================================================================
readonly DEVICE_ID="cam1"
#===============================================================================

readonly BASE_URL="http://netstorm.site/${DEVICE_ID}"
readonly REBOOT="${REBOOT_ON_FAIL:-no}"

# Exit codes
readonly EXIT_SUCCESS=0
readonly EXIT_WEB_SETUP_FAIL=2
readonly EXIT_SCRIPT_SETUP_FAIL=3
readonly EXIT_SERVICE_START_FAIL=4

#===============================================================================
# HELP & VERSION
#===============================================================================
show_version() {
    cat <<EOF
${SCRIPT_NAME} v${SCRIPT_VERSION}
Author: ${SCRIPT_AUTHOR}
EOF
    exit 0
}

show_help() {
    cat <<EOF
Usage: ${0##*/} [OPTIONS]

${SCRIPT_NAME} - Initializes Raspberry Pi camera system on boot

This script performs the following tasks:
  - Tests camera hardware and connectivity
  - Downloads and sets up web interface files
  - Downloads and configures runtime scripts
  - Starts all camera services (sync, main, live, tunnel, monitor)
  - Configures WiFi settings for optimal performance
  - Loads optional plugins from manifest

OPTIONS:
    -h, --help      Show this help message
    -v, --version   Show version information
    -d, --debug     Enable debug mode (set -x)

ENVIRONMENT VARIABLES:
    DEVICE_ID       Camera device ID (default: cam1)
    BASE_URL        Server base URL (default: http://netstorm.site/cam1)
    REBOOT_ON_FAIL  Enable auto-reboot on camera failure (yes/no, default: no)

EXAMPLES:
    ${0##*/}                           # Run with defaults
    DEVICE_ID=cam2 ${0##*/}            # Run for camera 2
    REBOOT_ON_FAIL=yes ${0##*/}        # Enable auto-reboot
    ${0##*/} --help                    # Show this help

EXIT CODES:
    0    Success - Boot completed
    1    General error
    2    Web setup failed
    3    Script setup failed
    4    Service start failed

FILES:
    /var/www/html/              Web interface files
    /tmp/                       Runtime scripts and status files
    /tmp/status/                Service status directory

AUTHOR:
    Written by ${SCRIPT_AUTHOR}

REPORTING BUGS:
    Report bugs to: http://netstorm.site/support
EOF
    exit 0
}

#######################################
# Get WiFi MAC address using pure Bash.
# Tries /sys filesystem first, falls back to ip command.
# Globals:
#   None
# Arguments:
#   None
# Outputs:
#   Writes MAC address to stdout, or 'unknown' if not found
# Returns:
#   0 always
#######################################
get_mac() {
    local mac_file="/sys/class/net/wlan0/address"
    [[ -r $mac_file ]] && { printf '%s' "$(<"$mac_file")"; return; }

    command -v ip &>/dev/null && {
        local out
        out="$(ip link show wlan0 2>/dev/null)"
        [[ $out =~ link/ether[[:space:]]+([0-9a-f:]+) ]] && {
            printf '%s' "${BASH_REMATCH[1]}"
            return
        }
    }
    printf 'unknown'
}

MAC="$(get_mac)"
readonly MAC

#######################################
# Cleanup function called on EXIT/INT/TERM signals.
# Removes temporary files and terminates background jobs.
# Globals:
#   BASE_URL
#   EXIT_SUCCESS
# Arguments:
#   None
# Returns:
#   Exits with last command exit code
#######################################
cleanup() {
    local exit_code=$?
    # Clean up any leftover temp files
    rm -f /tmp/camera_test_*.jpg 2>/dev/null || :

    local pid
    for pid in $(jobs -p 2>/dev/null); do
        kill -TERM "$pid" 2>/dev/null || :
        wait "$pid" 2>/dev/null || :
    done

    ((exit_code != EXIT_SUCCESS)) && {
        printf '[%s] [ERROR] Exit code: %s\n' "$(date '+%H:%M:%S')" "$exit_code" >&2
        curl -sf --data "file=log/log.txt&data=[ERROR] Exit Code: ${exit_code}, $(TZ=Asia/Kuwait date '+%d/%m/%Y %I:%M:%S %p')." "${BASE_URL}/storage.php" -m 3 >/dev/null 2>&1 || :
    }
    exit "$exit_code"
}

#######################################
# Error trap handler for ERR signal.
# Logs critical errors to console and remote server.
# Globals:
#   BASE_URL
# Arguments:
#   None (uses BASH_LINENO, FUNCNAME, BASH_COMMAND)
# Outputs:
#   Writes error message to stderr
# Returns:
#   0 always
#######################################
err_trap() {
    local exit_code=$?
    local line="${BASH_LINENO[0]}"
    local func="${FUNCNAME[1]:-main}"
    local cmd="${BASH_COMMAND}"

    printf '[%s] [ERROR] Command failed (exit %s) at line %s in %s(): %s\n' \
        "$(date '+%H:%M:%S')" "$exit_code" "$line" "$func" "$cmd" >&2

    # Log to server for critical errors
    curl -sf --data "file=log/error.txt&data=[CRITICAL] Line ${line} in ${func}(): ${cmd} (exit ${exit_code})" \
        "${BASE_URL}/storage.php" -m 2 >/dev/null 2>&1 || :
}

trap cleanup EXIT INT TERM
trap err_trap ERR

#######################################
# Log message to console with timestamp.
# Arguments:
#   $1 - Log level (INFO, WARN, ERROR)
#   $2 - Log message
# Outputs:
#   Writes formatted log message to stdout
#######################################
log() { printf '[%s] [%s] %s\n' "$(date '+%H:%M:%S')" "$1" "$2"; }

#######################################
# Log message to remote server via HTTP.
# Globals:
#   BASE_URL
# Arguments:
#   $1 - Log level
#   $2 - Log message
# Returns:
#   0 always (errors suppressed)
#######################################
log_web() {
    curl -sf --data "file=log/log.txt&data=$1 $2 $(TZ=Asia/Kuwait date '+%d/%m %H:%M:%S')" "${BASE_URL}/storage.php" -m 3 >/dev/null 2>&1 || :  # FAST MODE - reduced from 5s
}


#######################################
# Download file from URL with retry logic (3 attempts).
# Arguments:
#   $1 - URL to download from
#   $2 - Output file path
# Returns:
#   0 on success, 1 on failure after 3 attempts
#######################################
dl() {
    local url=$1 out=$2 try=0
    while ((try++ < 3)); do
        wget -qO "$out" "$url" 2>/dev/null && [[ -s $out ]] && return 0
        [[ -f $out ]] && rm -f "$out"
        sleep 1
    done
    log "ERROR" "Download failed: ${out##*/}"
    return 1
}

#######################################
# Test camera hardware and take test photo.
# Checks if camera is detected and not busy, then takes test image.
# Globals:
#   REBOOT
# Outputs:
#   Writes log messages to stdout and server
# Returns:
#   0 if camera test successful, 1 if failed
#######################################
test_cam() {
    log "INFO" "Testing camera..."

    # Check detection (Pure Bash)
    local cam_info
    cam_info="$(vcgencmd get_camera 2>/dev/null)"
    [[ $cam_info == *"detected=1"* ]] || {
        log "WARN" "Camera not detected"
        log_web "ERROR" "Camera Not Connected"
        return 1
    }

    # Check if busy (Pure Bash - avoid ls/grep)
    local fd link
    for fd in /proc/*/fd/*; do
        [[ -L $fd ]] || continue
        link="$(readlink "$fd" 2>/dev/null)" || continue
        [[ $link == "/dev/video0" ]] && {
            log "WARN" "Camera busy"
            log_web "ERROR" "Camera Busy"
            return 1
        }
    done

    # Capture, optimize, upload (fixed filename for server compatibility)
    local temp_img="/tmp/test.jpg"

    # Remove old test file if exists
    [[ -f "$temp_img" ]] && rm -f "$temp_img"

    if raspistill -n -t 300 -q 5 -o "$temp_img" -a 1020 2>/dev/null && \
       [[ -s "$temp_img" ]] && \
       jpegoptim --strip-all "$temp_img" 2>/dev/null && \
       curl -sf -F "upfile=@${temp_img}" "${BASE_URL}/storage.php" -m 10 >/dev/null 2>&1; then
        :
    else
        log "WARN" "Camera test failed"
        log_web "ERROR" "Camera Test Failed"
        [[ -f "$temp_img" ]] && rm -f "$temp_img"
        return 1
    fi

    rm -f "$temp_img"
    log "INFO" "Camera ready"
    return 0
}

#######################################
# Check camera with retry logic (3 attempts).
# Globals:
#   REBOOT
# Returns:
#   0 if camera passes test, 1 otherwise
#######################################
check_cam() {
    local i=0
    while ((i++ < 3)); do
        test_cam && { log_web "OK" "Camera Ready"; return 0; }
        ((i < 3)) && {
            log "WARN" "Retrying camera (${i}/3)..."
            log_web "RETRY" "Camera Test ${i}/3"
            sleep 1  # FAST MODE - reduced from 2s
        }
    done
    log "WARN" "Camera check failed"
    log_web "FAIL" "Camera Failed All Tests"
    [[ $REBOOT == yes ]] && { log_web "SYSTEM" "Rebooting"; sleep 1; reboot -f; }
    log_web "SYSTEM" "Auto-Reboot Disabled"
    return 1
}

#######################################
# Setup web interface files in /var/www/html.
# Downloads HTML, CSS, JS, PHP files from server in parallel.
# Globals:
#   BASE_URL
# Returns:
#   0 on success, 1 on failure
#######################################
setup_web() {
    [[ -f /var/www/html/captura.php ]] && {
        log "INFO" "Web files present"
        log_web "INFO" "Web Files Already Present"
        return 0
    }

    cd /var/www/html || return 1
    log "INFO" "Setting up web files"
    log_web "INFO" "Setting Up Web Files"

    # Create files (Pure Bash)
    : >index.html
    printf '%s\n' "3 5 33333 -35 0 none 100" >var.tmp
    printf '%s\n' "off" >onoff.tmp
    printf '%s\n' "off" >libre.tmp
    printf '%s\n' "off" >monitor.tmp
    chown www-data:www-data ./*.tmp 2>/dev/null || :

    # Parallel downloads
    {
        dl "${BASE_URL}/web/file_mon.css" file.css
        dl "${BASE_URL}/jquery-3.7.1.min.js" jquery-3.7.1.min.js
        dl "${BASE_URL}/logo.ico" logo.ico
    } &
    {
        dl "${BASE_URL}/web/phpwritefile_" write_file_.php
        dl "${BASE_URL}/web/phpcaptura_" captura.php
        dl "${BASE_URL}/web/pinch-zoom.js" pinch-zoom.js
    } &
    {
        dl "${BASE_URL}/script/shmonitor_" monitor.sh
        dl "${BASE_URL}/web/mini.jpg" mini.jpg
        dl "${BASE_URL}/web/buffer.jpg" buffer.jpg
    } &
    wait

    chmod +x ./*.{php,sh} 2>/dev/null || :
    log "INFO" "Web setup complete"
    log_web "OK" "Web Files Setup Complete"
}


#######################################
# Setup runtime scripts in /tmp directory.
# Downloads all camera service scripts from server in parallel.
# Globals:
#   BASE_URL
# Returns:
#   0 on success, 1 on failure
#######################################
setup_scripts() {
    cd /tmp || return 1
    : >url.tmp
    [[ -d status ]] || mkdir -p status
    chmod 777 status 2>/dev/null || :

    log "INFO" "Downloading scripts"
    log_web "INFO" "Downloading Scripts"

    # Parallel downloads
    {
        dl "${BASE_URL}/script/shsync_" sync.sh
        dl "${BASE_URL}/script/shlive_" live.sh
        dl "${BASE_URL}/script/shtunel_" tunel.sh
    } &
    {
        dl "${BASE_URL}/script/shtunel2_" tunel2.sh
        dl "${BASE_URL}/script/shtunel3_" tunel3.sh
        dl "${BASE_URL}/script/shtunel4_" tunel4.sh
    } &
    {
        dl "${BASE_URL}/script/shmain_" main.sh
        dl "${BASE_URL}/script/shcleanup_" cleanup.sh
    } &
    wait

    chmod +x ./*.sh 2>/dev/null || :

    log "INFO" "Scripts setup complete"
    log_web "OK" "Scripts Downloaded & Ready"
}

#######################################
# Start all camera services in background.
# Starts sync, main, live, tunnel, and cleanup scripts.
# Returns:
#   0 always
#######################################
start_services() {
    cd /tmp || return 1
    log "INFO" "Starting services"
    log_web "INFO" "Starting Services"

    # Create PID directory
    mkdir -p /tmp/status 2>/dev/null || true

    # Start core services
    [[ -x ./sync.sh ]] && nohup ./sync.sh >/dev/null 2>&1 &
    [[ -x ./main.sh ]] && nohup ./main.sh >/dev/null 2>&1 &
    [[ -x ./live.sh ]] && nohup ./live.sh >/dev/null 2>&1 &

    # Start tunnel processes
    [[ -x ./tunel.sh ]] && nohup ./tunel.sh start >/dev/null 2>&1 &
    [[ -x ./tunel2.sh ]] && nohup ./tunel2.sh start >/dev/null 2>&1 &
    [[ -x ./tunel3.sh ]] && nohup ./tunel3.sh start >/dev/null 2>&1 &
    [[ -x ./tunel4.sh ]] && nohup ./tunel4.sh start >/dev/null 2>&1 &

    # Start cleanup service
    #[[ -x ./cleanup.sh ]] && nohup ./cleanup.sh >/dev/null 2>&1 &

    # Monitor service (runs in /var/www/html)
    if [[ -x /var/www/html/monitor.sh ]]; then
        (cd /var/www/html && nohup ./monitor.sh >/dev/null 2>&1 &)
    fi

    # Give services time to start - FAST MODE
    sleep 0.5

    log_web "OK" "Services Started"
}

#######################################
# Configure WiFi power settings for optimal performance.
# Sets TX power to maximum and disables power save.
# Returns:
#   0 always
#######################################
setup_wifi() {
    [[ -e /sys/class/net/wlan0 ]] || return 0
    if command -v iwconfig &>/dev/null; then
        iwconfig wlan0 txpower 26 2>/dev/null || :
    fi
    if command -v iw &>/dev/null; then
        iw wlan0 set power_save off 2>/dev/null || :
    fi
    log_web "OK" "WiFi Configured"
}

#######################################
# Load optional plugins from server manifest.
# Downloads and executes plugin scripts if manifest exists.
# Uses pure Bash (no jq) to parse JSON.
# Globals:
#   BASE_URL
# Returns:
#   0 always (non-fatal)
#######################################
load_plugins() {
    cd /tmp || return 0

    log "INFO" "Checking for plugins"

    # Download manifest (try secure download first)
    local manifest="/tmp/plugins_manifest.json"
    if ! secure_download "${BASE_URL}/includes/plugins/manifest.json" "$manifest" "" && \
       ! wget -qO "$manifest" "${BASE_URL}/includes/plugins/manifest.json" 2>/dev/null; then
        log "INFO" "No plugins manifest - skipping"
        [[ -f $manifest ]] && rm -f "$manifest"
        return 0
    fi

    [[ ! -s $manifest ]] && {
        log "INFO" "No plugins manifest - skipping"
        [[ -f $manifest ]] && rm -f "$manifest"
        return 0
    }

    log "INFO" "Plugins manifest found"

    # Parse manifest for enabled plugins (Pure Bash)
    local in_plugin=0 plugin_name="" plugin_script="" plugin_enabled=""

    while IFS= read -r line; do
        # Detect plugin name (skip top-level "plugins" key)
        [[ $line =~ \"([^\"]+)\":[[:space:]]*\{ ]] && {
            plugin_name="${BASH_REMATCH[1]}"
            [[ $plugin_name == "plugins" ]] && continue  # Skip root object
            in_plugin=1
            plugin_script=""
            plugin_enabled=""
            continue
        }

        # Inside plugin block
        ((in_plugin)) && {
            # Check enabled status
            [[ $line =~ \"enabled\":[[:space:]]*(true|false) ]] && {
                plugin_enabled="${BASH_REMATCH[1]}"
            }

            # Get script path
            [[ $line =~ \"script\":[[:space:]]*\"([^\"]+)\" ]] && {
                plugin_script="${BASH_REMATCH[1]}"
            }

            # End of plugin block
            [[ $line =~ \} ]] && {
                in_plugin=0

                # Load plugin if enabled and has script
                if [[ $plugin_enabled == "true" && -n $plugin_script ]]; then
                    log "INFO" "Loading plugin: ${plugin_name}"

                    local script_url="${BASE_URL}/includes/plugins/${plugin_script}"
                    local script_file="/tmp/plugin_${plugin_name}.sh"

                    # Try secure download first, fallback to wget
                    local download_ok=0
                    if secure_download "$script_url" "$script_file" ""; then
                        download_ok=1
                    elif wget -qO "$script_file" "$script_url" 2>/dev/null && [[ -s $script_file ]]; then
                        download_ok=1
                    fi

                    if ((download_ok)); then
                        chmod +x "$script_file" 2>/dev/null || :

                        # Start plugin in background from /tmp directory
                        ( cd /tmp && [[ -x ./plugin_${plugin_name}.sh ]] && ./plugin_"${plugin_name}".sh >/dev/null 2>&1 & )

                        log "INFO" "Plugin started: ${plugin_name}"
                        log_web "OK" "Plugin Loaded: ${plugin_name}"
                    else
                        log "WARN" "Plugin script not found: ${plugin_name}"
                        log_web "WARN" "Plugin ${plugin_name} in manifest but file missing"
                        [[ -f $script_file ]] && rm -f "$script_file"
                    fi
                fi
            }
        }
    done < "$manifest"

    rm -f "$manifest"
    log "INFO" "Plugin loading complete"
}

#-------------------------------------------------------------------------------
# Main
#-------------------------------------------------------------------------------
main() {
    local cam="NOT Connected" start
    start="$(date +%s)"

    log "INFO" "=== Boot Starting ==="
    log "INFO" "Device: ${DEVICE_ID}"
    log "INFO" "MAC: ${MAC}"
    log_web "INFO" "Boot Starting - ${DEVICE_ID}"

    check_cam && cam="READY"

    setup_web || {
        log "ERROR" "Web setup failed"
        log_web "ERROR" "Web Setup Failed"
        exit "$EXIT_WEB_SETUP_FAIL"
    }

    setup_scripts || {
        log "ERROR" "Scripts setup failed"
        log_web "ERROR" "Scripts Setup Failed"
        exit "$EXIT_SCRIPT_SETUP_FAIL"
    }

    start_services || {
        log "ERROR" "Services start failed"
        log_web "ERROR" "Services Start Failed"
        exit "$EXIT_SERVICE_START_FAIL"
    }

    setup_wifi

    load_plugins

    local dur="$(($(date +%s) - start))"

    log "INFO" "=== Boot Complete ==="
    log "INFO" "Device: ${DEVICE_ID}"
    log "INFO" "MAC: ${MAC}"
    log "INFO" "Camera: ${cam}"
    log "INFO" "Duration: ${dur}s"

    log_web "SUCCESS" "BOOTED - Cam: ${cam} | Device: ${DEVICE_ID^^} - MAC: ${MAC} | Duration: ${dur}s"
}

#===============================================================================
# PARSE COMMAND LINE ARGUMENTS
#===============================================================================
# Parse arguments before main
[[ "${BASH_SOURCE[0]}" == "${0}" ]] && {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)    show_help ;;
            -v|--version) show_version ;;
            -d|--debug)   set -x; shift ;;
            *)            echo "Unknown option: $1" >&2; show_help ;;
        esac
    done
    main
}
