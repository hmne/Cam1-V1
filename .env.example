# =============================================================================
# Camera Control Center - Environment Configuration Template
# =============================================================================
#
# SECURITY NOTICE (OWASP Top 10 - A02:2021 Cryptographic Failures)
# ------------------------------------------------------------------
# 1. Copy this file to '.env' (it will be ignored by git)
# 2. Replace ALL placeholder values with your actual credentials
# 3. Set file permissions: chmod 600 .env
# 4. NEVER commit .env to version control
# 5. Rotate credentials regularly (every 90 days recommended)
#
# Standards Applied:
# - Twelve-Factor App (III. Config - Store config in environment)
# - OWASP ASVS (Application Security Verification Standard)
# - NIST SP 800-53 (Security and Privacy Controls)
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment: development, staging, production
APP_ENV=production

# Debug mode: true (development only), false (production - REQUIRED)
# SECURITY: NEVER enable debug in production (OWASP A05:2021 Security Misconfiguration)
APP_DEBUG=false

# Timezone: See https://www.php.net/manual/en/timezones.php
APP_TIMEZONE=Asia/Kuwait

# -----------------------------------------------------------------------------
# Camera Configuration
# -----------------------------------------------------------------------------
# Camera unique identifier (alphanumeric, lowercase, no spaces)
# Pattern: ^[a-z0-9-]+$
CAMERA_ID=cam1-v1

# Display name (human-readable, shown in UI)
CAMERA_DISPLAY_NAME="N.S-Cam1"

# CRITICAL: Replace 'example.com' with your actual domain or IP
# Examples:
#   - Domain: https://camera.example.com/cam1-v1
#   - IP: http://192.168.1.100/cam1-v1
#   - Subdirectory: https://example.com/cameras/cam1-v1
CAMERA_BASE_URL="https://example.com/cam1-v1"

# Camera offline timeout (seconds) - marks camera offline if no heartbeat
# Recommended: 15-30 seconds
CAMERA_ONLINE_TIMEOUT=15

# -----------------------------------------------------------------------------
# Performance Settings
# -----------------------------------------------------------------------------
# SPEED_MODE: Use static background image instead of video
# true = faster (recommended for mobile), false = video background
SPEED_MODE=false

# JavaScript engine mode
# Options: 'normal' (jQuery), 'fast' (Vanilla JS), 'ultra' (aggressive optimization)
# Recommendation: 'fast' for best performance/compatibility balance
JS_MODE=normal

# -----------------------------------------------------------------------------
# WebSocket Configuration (Real-time Updates)
# -----------------------------------------------------------------------------
# Enable WebSocket for real-time updates (recommended)
# Requires WebSocket server running on VPS
WEBSOCKET_ENABLED=true

# WebSocket Server URL
# CRITICAL: Replace with your actual VPS IP and port
# Format: wss://YOUR_VPS_IP:PORT (wss = secure WebSocket)
# Example: wss://203.0.113.45:8443
#
# Setup Guide: See /websocket/README.md
WEBSOCKET_SERVER_URL="wss://YOUR_VPS_IP:8443"

# -----------------------------------------------------------------------------
# SSH Credentials (for remote camera management)
# -----------------------------------------------------------------------------
# SECURITY WARNING (OWASP A07:2021 Identification and Authentication Failures)
# These credentials allow remote reboot/shutdown/cleanup operations
#
# Best Practices:
# 1. Use SSH key authentication instead of passwords (preferred)
# 2. Create dedicated service account with minimal privileges
# 3. Use sudo configuration for specific commands only
# 4. Enable fail2ban to prevent brute force attacks
# 5. Restrict SSH access by IP (iptables/firewall)
#
# Example sudoers entry (/etc/sudoers.d/camera-service):
#   camera-user ALL=(ALL) NOPASSWD: /sbin/reboot, /sbin/shutdown
#
SSH_USERNAME=your_ssh_username
SSH_PASSWORD="your_ssh_password_or_leave_empty_for_key_auth"

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
# Session cookie security (OWASP A05:2021 Security Misconfiguration)
# CRITICAL: Set to 'true' if using HTTPS (REQUIRED for production)
SESSION_COOKIE_SECURE=true

# Session lifetime (seconds) - auto-logout after inactivity
# Recommended: 3600 (1 hour) for security, 28800 (8 hours) for convenience
SESSION_LIFETIME=3600

# File operation limits (bytes) - prevents DoS attacks
MAX_READABLE_FILE_SIZE=1048576    # 1 MB
MAX_UPLOADABLE_FILE_SIZE=80000000 # 80 MB

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log channel: file, syslog, errorlog
LOG_CHANNEL=file

# Log level: debug, info, notice, warning, error, critical, alert, emergency
# Production: info or warning, Development: debug
LOG_LEVEL=info

# Log file path (relative to application root)
LOG_PATH=log/app.log

# -----------------------------------------------------------------------------
# Live Stream Settings
# -----------------------------------------------------------------------------
# Default quality preset
# Options: very-low (480x360), low (640x480), medium (800x600), high (1024x768)
# Recommendation: very-low for mobile, medium for desktop
DEFAULT_LIVE_QUALITY=very-low

# Page Visibility Optimization (reduces updates when tab is hidden)
# true = saves battery on mobile, false = continuous updates for monitoring displays
ENABLE_PAGE_VISIBILITY_OPTIMIZATION=true

# -----------------------------------------------------------------------------
# API Keys (Optional Features)
# -----------------------------------------------------------------------------
# Google Cloud Vision API (for OCR module)
# Get your key: https://console.cloud.google.com/apis/credentials
# Leave empty to disable OCR features
GOOGLE_VISION_API_KEY=""

# -----------------------------------------------------------------------------
# Advanced Settings (Optional - Only change if you know what you're doing)
# -----------------------------------------------------------------------------
# PHP Memory Limit (format: 128M, 256M, 512M)
# PHP_MEMORY_LIMIT=256M

# Maximum execution time for scripts (seconds)
# PHP_MAX_EXECUTION_TIME=30

# Enable OPcache for better PHP performance (true/false)
# PHP_OPCACHE_ENABLED=true

# CORS allowed origins (comma-separated, for API access)
# CORS_ALLOWED_ORIGINS="https://example.com,https://app.example.com"

# Rate limiting (requests per minute per IP)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX_REQUESTS=60

# =============================================================================
# Configuration Checklist (Before Going to Production)
# =============================================================================
#
# [ ] Replaced ALL placeholder values (search for 'example.com', 'YOUR_')
# [ ] Set APP_DEBUG=false
# [ ] Set APP_ENV=production
# [ ] Configured HTTPS and set SESSION_COOKIE_SECURE=true
# [ ] Set strong SSH credentials or configured SSH key authentication
# [ ] Configured WebSocket server (or disabled WEBSOCKET_ENABLED)
# [ ] Set file permissions: chmod 600 .env
# [ ] Added .env to .gitignore (verify: git status should NOT show .env)
# [ ] Configured firewall rules (SSH, HTTPS ports only)
# [ ] Set up automated backups for configuration
# [ ] Documented recovery procedures
# [ ] Tested failure scenarios (network down, camera offline, etc.)
#
# =============================================================================
