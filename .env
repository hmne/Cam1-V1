# =============================================================================
# Camera Control Center - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Kuwait

# -----------------------------------------------------------------------------
# Camera Configuration
# -----------------------------------------------------------------------------
CAMERA_ID=cam1-v1
CAMERA_DISPLAY_NAME="N.S-Cam1"
CAMERA_BASE_URL="http://XX.com/cam1-v1"
CAMERA_ONLINE_TIMEOUT=15

# -----------------------------------------------------------------------------
# Performance Settings
# -----------------------------------------------------------------------------
SPEED_MODE=false
JS_MODE=normal

# -----------------------------------------------------------------------------
# WebSocket Configuration
# -----------------------------------------------------------------------------
WEBSOCKET_ENABLED=true
WEBSOCKET_SERVER_URL="wss://XX.XX.XX.XX:XX"

# -----------------------------------------------------------------------------
# SSH Credentials
# -----------------------------------------------------------------------------
SSH_USERNAME=XX
SSH_PASSWORD="XX"

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
SESSION_COOKIE_SECURE=false
SESSION_LIFETIME=3600
MAX_READABLE_FILE_SIZE=1048576
MAX_UPLOADABLE_FILE_SIZE=80000000

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_CHANNEL=file
LOG_LEVEL=info
LOG_PATH=log/app.log

# -----------------------------------------------------------------------------
# Live Stream Settings
# -----------------------------------------------------------------------------
DEFAULT_LIVE_QUALITY=very-low
ENABLE_PAGE_VISIBILITY_OPTIMIZATION=true
